{
	"name": "doki",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"test": "vitest",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"test:e2e": "playwright test",
		"test:coverage": "vitest run --coverage",
		"db:migrate": "tsx node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
		"db:rollback": "tsx node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
		"db:seed": "tsx node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
		"db:migrate:make": "tsx node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.726.1",
		"@aws-sdk/s3-request-presigner": "^3.726.1",
		"argon2": "^0.44.0",
		"bcryptjs": "^2.4.3",
		"camelcase-keys": "^10.0.2",
		"jose": "^5.9.6",
		"knex": "^3.1.0",
		"lodash": "^4.17.23",
		"next": "16.1.6",
		"pg": "^8.13.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@playwright/test": "^1.50.0",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.2.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/lodash": "^4.17.23",
		"@types/node": "^20",
		"@types/pg": "^8.11.10",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^3.0.5",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.3",
		"eslint-config-next": "16.1.6",
		"husky": "^9.1.7",
		"jsdom": "^26.0.0",
		"prettier": "^3.8.1",
		"tailwindcss": "^4",
		"tsx": "^4.21.0",
		"typescript": "^5",
		"vitest": "^3.0.5"
	}
}
